{
  "name": "@klh-app/use-theme",
  "version": "1.0.2",
  "description": "Dark mode for any React app",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "keywords": [
    "react",
    "theme",
    "dark-mode",
    "light-mode",
    "useSyncExternalStore",
    "hook",
    "system-preference",
    "prefers-color-scheme",
    "ssr",
    "tailwind",
    "css-variables"
  ],
  "author": "klh",
  "license": "MIT",
  "homepage": "https://github.com/klh-app/use-theme#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/klh-app/use-theme.git"
  },
  "bugs": {
    "url": "https://github.com/klh-app/use-theme/issues"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
