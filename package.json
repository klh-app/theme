{
  "name": "@klh-app/theme",
  "version": "1.0.0",
  "description": "React 18+ theme management hook built on useSyncExternalStore",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "react",
    "theme",
    "dark-mode",
    "light-mode",
    "useSyncExternalStore",
    "hook",
    "system-preference",
    "prefers-color-scheme",
    "ssr",
    "tailwind",
    "css-variables"
  ],
  "author": "klh",
  "license": "MIT",
  "homepage": "https://klh.app/theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/klh-app/theme.git"
  },
  "engines": {
    "node": ">=18"
  }
}
